---
title: "Portfolio feed"
summary: "Recent portfolio entries from this Eleventy boilerplate."
permalink: "/portfolio/feed.xml"
---
{% set feedBaseUrl = site.absoluteUrl or site.url %}
{% set feedItems = collections.portfolioItems | latestItems(25) %}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.name }} {{ title }}</title>
  <subtitle>{{ summary }}</subtitle>
  <link href="{{ feedBaseUrl }}{{ permalink }}" rel="self"/>
  <link href="{{ feedBaseUrl }}/portfolio/"/>
  <updated>{{ feedItems | rssLastUpdatedDate }}</updated>
  <id>{{ feedBaseUrl }}{{ "/portfolio/" }}</id>
  <author>
    <name>{{ site.authorName }}</name>
    <email>{{ site.authorEmail }}</email>
  </author>
  {% for item in feedItems %}
    {% set absoluteItemUrl %}{{ feedBaseUrl }}{{ item.url | url }}{% endset %}
    <entry>
      <title>{{ item.data.title }}</title>
      <link href="{{ absoluteItemUrl }}"/>
      <updated>{{ (item.data.date or item.date) | rssDate }}</updated>
      <id>{{ absoluteItemUrl }}</id>
      <author>
        <name>{{ item.data.author or site.authorName }}</name>
        <email>{{ site.authorEmail }}</email>
      </author>
      <summary>{{ item | feedSummary(280) | escape }}</summary>
    </entry>
  {% endfor %}
</feed>
