---
pagination:
  data: collections.caseStudiesCategoryPages
  size: 1
  alias: categoryPage
  addAllPagesToCollections: true
layout: false
permalink: "{{ categoryPage.permalink }}"
---

{% extends "layouts/base.html" %}

{% block content %}

{% set caseStudyItems = collections.caseStudiesItems | filterCaseStudiesByCategory(categoryPage.category) %}

<div class="layout" data-layout="amsterdam">

</div><!-- layout -->

<div data-layout="grid" data-variation="bordered" data-opposite="true">

{% set listedCaseStudies = caseStudyItems or collections.caseStudiesItems %}

{% for item in listedCaseStudies %}
{% if item.url != page.url and item.url != excludeCaseStudyUrl %}
<div>
<article class="item-case-study" data-case-study-card data-case-study-categories="{% if item.data.categories and item.data.categories.length %}{% for category in item.data.categories %}{{ category | slug }}{% if not loop.last %} {% endif %}{% endfor %}{% endif %}">

<div>

{% if item.data.image %}<figure>
<a href="{{ item.url }}"><img src="/images/{{ item.data.image }}" alt="{{ item.data.title }}"></a>
</figure>{% endif %}

{% if item.data.clientName %}<small class="alt-meta">{{ item.data.clientName }}</small>{% endif %}
<h2 data-size="2xl"><a href="{{ item.url }}">{{ item.data.title }}</a></h2>
{% if item.data.summary %}<p>{{ item.data.summary }}</p>{% endif %}
</div>

<div class="btn-cta" data-variation="icon">
{% include "partials/svgs/icon-logomark.svg" %}
<a href="{{ item.url }}" class="btn" data-variant="secondary">Read the story</a>
</div><!-- btn-cta -->

</article>
</div>
{% endif %}
{% endfor %}

</div><!-- grid -->

{% endblock %}
