{% if item.data.clientName or item.data.year or item.data.featured %}
<p>
{% if item.data.clientName %}
{{ item.data.clientName }}
{% endif %}
{% if item.data.year %}
{% if item.data.clientName %} • {% endif %}{{ item.data.year }}
{% endif %}
{% if item.data.featured %}
{% if item.data.clientName or item.data.year %} • {% endif %}Featured
{% endif %}
</p>
{% endif %}

{% if item.data.lede %}<p>{{ item.data.lede }}</p>{% endif %}
{% if item.data.summary %}<p>{{ item.data.summary }}</p>{% endif %}

{% if item.data.summarySection and item.data.summarySection.items %}
<ul>
{% for summaryItem in item.data.summarySection.items %}
<li><strong>{{ summaryItem.summaryTitle }}</strong>: {{ summaryItem.summaryText }}</li>
{% endfor %}
</ul>
{% endif %}

{{ item.templateContent | safe }}

{% if item.data.result %}
<h2>Result</h2>
{{ item.data.result | markdown | safe }}
{% endif %}

{% if item.data.whatChanged and item.data.whatChanged.items %}
<h2>What changed</h2>
<ul>
{% for changedItem in item.data.whatChanged.items %}
{% if changedItem.listItem %}<li>{{ changedItem.listItem }}</li>{% endif %}
{% endfor %}
</ul>
{% endif %}

{% if item.data.categories and item.data.categories.length %}
<p><strong>Categories:</strong> {{ item.data.categories | join(", ") }}</p>
{% endif %}
